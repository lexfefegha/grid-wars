{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/node_modules/**",
            "scope.md",
            "prompts1.md",
            "prompts2.md",
            "prompts3.md",
            "README.md"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "database": {
        "rules": "database.rules.json"
    }
}
